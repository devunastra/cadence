# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Webhook shared secrets (generate random strings, e.g. openssl rand -hex 32)
GHL_WEBHOOK_SECRET=your-ghl-webhook-secret

# Cron / admin endpoint protection (generate a random string)
CRON_SECRET=your-cron-secret

# GHL API
GHL_API_KEY=your-ghl-api-key
GHL_PHONE_NUMBER=+1234567890

# App URL (used in staff invite redirect links)
NEXT_PUBLIC_SITE_URL=https://your-app.vercel.app

# Retell API (optional — can also be stored per-studio in the DB)
RETELL_API_KEY=your-retell-api-key
